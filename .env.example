# ─────────────────────────────────────────────────────────────
# POSEIDON — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Anthropic API key — required for AI Threat Assessment feature
# Get yours at https://console.anthropic.com
REACT_APP_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Live AIS data provider
# Platform runs on high-fidelity mock data without this.
# Supported: AISHub, MarineTraffic, Spire Maritime
# REACT_APP_AIS_PROVIDER_URL=wss://your-ais-feed.example.com
# REACT_APP_AIS_API_KEY=your-ais-key-here
